{
  "package_type": "PFLOTRAN Modeling Package",
  "version": "0.1",
  "created": "2026-05-13",
  "project": "sulfide_tailings_acidic_seepage_uranium_series_radionuclide_transport",
  "research_objective": "Design a PFLOTRAN reactive transport workflow for acidic seepage from sulfide-bearing uranium tailings entering a shallow aquifer, with emphasis on acid generation, carbonate buffering, U mobility, Ra/Pb/Po migration, and attenuation by mineral precipitation and sorption.",
  "scenario": "uranium_mine_tailings_to_shallow_aquifer",
  "solver_family": "PFLOTRAN",
