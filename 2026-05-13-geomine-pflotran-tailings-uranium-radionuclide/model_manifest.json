  "requires_professional_review": true,
  "process_modes": {
    "flow_candidates": [
      "RICHARDS for tailings/vadose-zone seepage",
      "saturated groundwater flow for fully saturated aquifer-only model"
    ],
    "transport": "advection_dispersion_reactive_transport",
    "reactive_transport": true,
    "thermal": "not_first_model_unless_temperature_or_rate_data_require_it",
