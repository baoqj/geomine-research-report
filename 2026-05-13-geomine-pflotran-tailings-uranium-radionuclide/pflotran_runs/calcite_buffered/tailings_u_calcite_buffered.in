# PFLOTRAN synthetic screening run generated by GeoMine Research.
# Purpose: test whether carbonate buffering can delay an acidic U/SO4 plume in
# a 1D shallow-aquifer column. This is a synthetic calculation, not a site model.

SIMULATION
  SIMULATION_TYPE SUBSURFACE
  PROCESS_MODELS
    SUBSURFACE_FLOW flow
      MODE RICHARDS
    /
    SUBSURFACE_TRANSPORT transport
      MODE GIRT
    /
  /
END

SUBSURFACE

NUMERICAL_METHODS FLOW
  LINEAR_SOLVER
    SOLVER DIRECT
  /
END

NUMERICAL_METHODS TRANSPORT
  LINEAR_SOLVER
    SOLVER DIRECT
  /
END

CHEMISTRY
  PRIMARY_SPECIES
    H+
    HCO3-
    Ca++
    SO4--
    UO2++
  /
  SECONDARY_SPECIES
    OH-
    CO3--
    CO2(aq)
    CaCO3(aq)
    CaHCO3+
    CaSO4(aq)
    UO2CO3(aq)
    UO2(CO3)2--
    UO2(CO3)3----
    CaUO2(CO3)3--
    Ca2UO2(CO3)3(aq)
  /
  PASSIVE_GAS_SPECIES
    CO2(g)
  /
  MINERALS
    Calcite
  /
  MINERAL_KINETICS
    Calcite
      RATE_CONSTANT 1.d-6 mol/m^2-sec
    /
  /
  DATABASE /software/pflotran/database/hanford.dat
  LOG_FORMULATION
  ACTIVITY_COEFFICIENTS TIMESTEP
  OUTPUT
    PH
    TOTAL
    ALL
  /
END

GRID
  TYPE STRUCTURED
  NXYZ 100 1 1
  BOUNDS
    0.d0 0.d0 0.d0
    100.d0 1.d0 1.d0
  /
END

FLUID_PROPERTY
  DIFFUSION_COEFFICIENT 1.d-9
END

MATERIAL_PROPERTY aquifer
  ID 1
  POROSITY 0.25d0
  TORTUOSITY 1.d0
  PERMEABILITY
    PERM_ISO 1.d-12
  /
  CHARACTERISTIC_CURVES default
END

CHARACTERISTIC_CURVES default
  SATURATION_FUNCTION VAN_GENUCHTEN
    LIQUID_RESIDUAL_SATURATION 0.2d0
    ALPHA 1.d-4
    M 0.5d0
    MAX_CAPILLARY_PRESSURE 1.d6
  /
  PERMEABILITY_FUNCTION MUALEM
    PHASE LIQUID
    LIQUID_RESIDUAL_SATURATION 0.2d0
    M 0.5d0
  /
END

OUTPUT
  TIMES y 5. 10. 15. 20. 25.
  FORMAT TECPLOT POINT
  VELOCITY_AT_CENTER
  VARIABLES
    LIQUID_PRESSURE
    LIQUID_DENSITY
  /
END

TIME
  FINAL_TIME 25.d0 y
  INITIAL_TIMESTEP_SIZE 1.d0 h
  MAXIMUM_TIMESTEP_SIZE 2.5d-1 y
END

REGION all
  COORDINATES
    0.d0 0.d0 0.d0
    100.d0 1.d0 1.d0
  /
END

REGION west
  FACE WEST
  COORDINATES
    0.d0 0.d0 0.d0
    0.d0 1.d0 1.d0
  /
END

REGION east
  FACE EAST
  COORDINATES
    100.d0 0.d0 0.d0
    100.d0 1.d0 1.d0
  /
END

FLOW_CONDITION initial_pressure
  TYPE
    LIQUID_PRESSURE DIRICHLET
  /
  LIQUID_PRESSURE 201325.d0
END

FLOW_CONDITION seepage_flux
  TYPE
    LIQUID_FLUX NEUMANN
  /
  LIQUID_FLUX 1.d0 m/y
END

TRANSPORT_CONDITION background_conc
  TYPE ZERO_GRADIENT
  CONSTRAINT_LIST
    0.d0 background
  /
END

TRANSPORT_CONDITION tailings_seepage
  TYPE DIRICHLET_ZERO_GRADIENT
  CONSTRAINT_LIST
    0.d0 acid_u_sulfate
  /
END

CONSTRAINT background
  CONCENTRATIONS
    H+      8.d0     P
    HCO3-   1.d-3    T
    Ca++    5.d-4    M  Calcite
    SO4--   1.d-4    T
    UO2++   1.d-9    T
  /
  MINERALS
    Calcite 1.d-3 1.d0 m^2/m^3
  /
END

CONSTRAINT acid_u_sulfate
  CONCENTRATIONS
    H+      3.d0     P
    HCO3-   1.d-6    T
    Ca++    1.d-6    T
    SO4--   5.d-3    T
    UO2++   1.d-6    T
  /
END

INITIAL_CONDITION
  FLOW_CONDITION initial_pressure
  TRANSPORT_CONDITION background_conc
  REGION all
END

BOUNDARY_CONDITION outlet
  FLOW_CONDITION initial_pressure
  TRANSPORT_CONDITION background_conc
  REGION east
END

BOUNDARY_CONDITION inlet
  FLOW_CONDITION seepage_flux
  TRANSPORT_CONDITION tailings_seepage
  REGION west
END

STRATA
  REGION all
  MATERIAL aquifer
END

END_SUBSURFACE
