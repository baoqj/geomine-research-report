80 keff = k * EXP(-alpha * TOTAL_TIME)
90 moles = keff * M * TIME * hfac
100 IF (moles > M) THEN moles = M
110 SAVE moles
-end

SOLUTION 1 acid_only_accessible_pyrite
    temp 25
    pH 7
    pe 8
    units mmol/kgw
    O(0) 0.26
    Na 0.01 charge
KINETICS 1
Pyrite_Acid
    -formula H2SO4 2
    -m0 0.012
    -parms 2.0e-9
    -step_divide 100
    -steps 90720000 in 150 steps
END

