40 H = ACT("H+")
50 hfac = (H / 1e-4)^n
60 IF (hfac < 0.05) THEN hfac = 0.05
70 IF (hfac > 20) THEN hfac = 20
80 keff = k * EXP(-alpha * TOTAL_TIME)
90 moles = keff * M * TIME * hfac
